    "package-platform": "node npm/package-platform.mjs"
  },
  "optionalDependencies": {
    "@id6tm/madr-tools-darwin-arm64": "0.1.0",
    "@id6tm/madr-tools-linux-arm64": "0.1.0",
    "@id6tm/madr-tools-linux-x64": "0.1.0",
    "@id6tm/madr-tools-win32-x64": "0.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
