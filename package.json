{
  "name": "@id6tm/madr-tools",
  "version": "0.1.0",
  "description": "Manage markdown architecture decision records",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/id6tm/madr-tools"
  },
  "bin": {
    "madr": "npm/madr.js"
  },
  "files": [
    "npm/madr.js",
